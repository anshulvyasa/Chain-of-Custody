// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Investigator {
  walletAddress String  @id
  name          String?
  badgeNumber   String?
  casesCreated  Case[]
}

model Case {
  caseId          String       @id // Corresponds to the smart contract caseId
  caseTitle       String
  createdAt       DateTime     @default(now())
  createdByWallet String
  createdBy       Investigator @relation(fields: [createdByWallet], references: [walletAddress])
  folders         Folder[]
}

enum FolderType {
  NORMAL
  SPECIAL
}

model Folder {
  id         String     @id @default(uuid())
  name       String
  type       FolderType @default(NORMAL)
  caseId     String
  case       Case       @relation(fields: [caseId], references: [caseId], onDelete: Cascade)
  parentId   String?
  parent     Folder?    @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  subFolders Folder[]   @relation("FolderToFolder")

  documentVersions DocumentVersion[]

  createdAt DateTime @default(now())

  @@unique([name, parentId, caseId]) // Ensures no duplicate folder in the same parent for a case
}

model DocumentVersion {
  id              String   @id @default(uuid())
  folderId        String
  folder          Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  fileUrl         String? // CID
  fileType        String?
  documentHash    String // Off-chain stored reference of the hash
  uploadTimestamp DateTime @default(now())
  uploaderWallet  String
}
