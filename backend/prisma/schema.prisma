generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Investigator {
  walletAddress    String  @id
  name             String?
  badgeNumber      String?
  authority        String?
  casesCreated     Case[]
  events           Event[] @relation("ActionInitiator")
  timesAddedToCase Event[] @relation("AddedTarget")
  restrictedPaths  InvestigatorRestrictedPath[]
}

model Case {
  caseId          String       @id // Corresponds to the smart contract caseId
  caseTitle       String
  createdAt       DateTime     @default(now())
  createdByWallet String
  createdBy       Investigator @relation(fields: [createdByWallet], references: [walletAddress])
  folders         Folder[]
  events          Event[]
}

enum FolderType {
  NORMAL
  SPECIAL
}

model Folder {
  id         String     @id @default(uuid())
  name       String
  type       FolderType @default(NORMAL)
  caseId     String
  case       Case       @relation(fields: [caseId], references: [caseId], onDelete: Cascade)
  parentId   String?
  parent     Folder?    @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  subFolders Folder[]   @relation("FolderToFolder")

  documentVersions DocumentVersion[]

  createdAt DateTime @default(now())

  @@unique([name, parentId, caseId]) // Ensures no duplicate folder in the same parent for a case
}

model DocumentVersion {
  id              String   @id @default(uuid())
  folderId        String
  folder          Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  fileUrl         String? // CID
  fileType        String?
  documentHash    String // Off-chain stored reference of the hash
  uploadTimestamp DateTime @default(now())
  uploaderWallet  String
}

enum EventType {
  CaseAdded
  InvestigatorAddedToCase
  InvestigatorRemovedFromCase
  DocumentHashAdded
  AccessDocument
  NewInvestigatorAdded
  RemoveExistingInvestigator
  RemoveCompromizedInvestigator
  InvestigatorPathRestricted
  InvestigatorPathUnrestricted
}

model InvestigatorRestrictedPath {
  id                 String       @id @default(uuid())
  investigatorWallet String
  investigator       Investigator @relation(fields: [investigatorWallet], references: [walletAddress], onDelete: Cascade)
  caseId             String
  documentPath       String

  @@unique([investigatorWallet, caseId, documentPath])
}

model Event {
  id        String    @id @default(uuid())
  type      EventType
  timestamp DateTime

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [caseId])

  initiatorAddress String
  initiatorWallet  Investigator @relation("ActionInitiator", fields: [initiatorAddress], references: [walletAddress])

  caseTitle String?

  involvedInvestigator       String?
  involvedInvestigatorWallet Investigator? @relation("AddedTarget", fields: [involvedInvestigator], references: [walletAddress])

  documentPath String?
  hash         String?
  cid          String?
  authority    String?
}
